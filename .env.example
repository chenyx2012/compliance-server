APP_NAME=compliance-gateway
ENV=dev

# Gateway
HOST=0.0.0.0
PORT=8000

# Upstream services (4 modules)
SERVICE_A_BASE_URL=http://127.0.0.1:9001
SERVICE_B_BASE_URL=http://127.0.0.1:9002
SERVICE_C_BASE_URL=http://127.0.0.1:9003
SERVICE_D_BASE_URL=http://127.0.0.1:9004
UPSTREAM_TIMEOUT_SECONDS=30

# Celery / Redis queue
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_TASK_QUEUE=compliance_scan
CELERY_RESULT_EXPIRES_SECONDS=86400
